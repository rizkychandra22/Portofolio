{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.5"
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/(css|js|images|favicon.ico)/(.*)", "dest": "/public/$1/$2" },
        { "src": "/livewire/(.*)", "dest": "/api/index.php" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}